VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Código de este sistema/empresa para el puente inter-sistema (transferencias entre
# dos Supabase). Por defecto 'mineral-group'. En el sistema del centro de acopio
# externo (p. ej. Paramana) se pone su propio código.
VITE_EMPRESA_CODIGO=mineral-group
